@page "/products"
@inject ApiService Api
@inject NavigationManager Navigation

<PageTitle>Products</PageTitle>

<div class="page-header">
    <div>
        <h4>Products</h4>
        <p>Manage your product catalog and variants</p>
    </div>
    <a href="/products/create" class="btn-primary-custom">
        <i class="bi bi-plus-lg"></i> Add Product
    </a>
</div>

@if (isLoading)
{
    <div class="spinner-wrap">
        <div class="spinner"></div>
        <span>Loading products...</span>
    </div>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert-clean error">
        <i class="bi bi-exclamation-circle"></i> @errorMessage
    </div>
}
else
{
    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="alert-clean success">
            <i class="bi bi-check-circle"></i> @successMessage
        </div>
    }

    <!-- Stat row -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-icon indigo"><i class="bi bi-box-seam"></i></div>
                <div>
                    <h6>Total Products</h6>
                    <div class="stat-value">@products.TotalCount</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-icon green"><i class="bi bi-diagram-3"></i></div>
                <div>
                    <h6>Total Combinations</h6>
                    <div class="stat-value">@(products.Items.Sum(p => p.Combinations.Count))</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-icon amber"><i class="bi bi-layers"></i></div>
                <div>
                    <h6>This Page</h6>
                    <div class="stat-value">@(products.Items.Count) / @pageSize</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Table card -->
    <div class="card">
        <div class="card-header-clean">
            <h6><i class="bi bi-table me-2"></i>Product List</h6>
            <span style="font-size:0.78rem;color:var(--text-muted);">
                Page @(page) of @products.TotalPages
            </span>
        </div>

        @if (!products.Items.Any())
        {
            <div class="empty-state">
                <i class="bi bi-inbox"></i>
                <p>No products found.</p>
            </div>
        }
        else
        {
            <table class="table-clean">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Product Name</th>
                        <th>Description</th>
                        <th>Variants</th>
                        <th>Combinations</th>
                        <th>Created</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in products.Items.Select((product, index) => new { product, index }))
                    {
                        <tr>
                            <td data-label="#" style="color:var(--text-muted);font-size:0.8rem;">
                                @(((page - 1) * pageSize) + item.index + 1)
                            </td>
                            <td data-label="Product Name">
                                <span style="font-weight:600;">@item.product.Name</span>
                            </td>
                            <td data-label="Description" style="color:var(--text-secondary);max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                                @(item.product.Description ?? "—")
                            </td>
                            <td data-label="Variants">
                                <span class="badge-pill badge-indigo">
                                    <i class="bi bi-tag"></i> @item.product.Variants.Count
                                </span>
                            </td>
                            <td data-label="Combinations">
                                <span class="badge-pill badge-green">
                                    <i class="bi bi-grid"></i> @item.product.Combinations.Count
                                </span>
                            </td>
                            <td data-label="Created" style="color:var(--text-secondary);font-size:0.8rem;">
                                @item.product.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")
                            </td>
                            <td data-label="Actions">
                                <div class="d-flex gap-2">
                                    <a href="/products/@item.product.Id" class="btn-icon" title="View Details">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <button class="btn-icon text-danger" title="Delete Product" @onclick="() => OpenDeleteDialog(item.product)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="pagination-wrap">
                <span>Showing @products.Items.Count of @products.TotalCount products</span>
                <div class="d-flex gap-2">
                    <button class="btn-ghost" @onclick="PreviousPage" disabled="@(page <= 1)">
                        <i class="bi bi-chevron-left"></i> Prev
                    </button>
                    <button class="btn-ghost" @onclick="NextPage" disabled="@(page >= products.TotalPages)">
                        Next <i class="bi bi-chevron-right"></i>
                    </button>
                </div>
            </div>
        }
    </div>

    @if (productToDelete is not null)
    {
        <div class="modal fade show d-block" tabindex="-1" role="dialog">
            <div class="modal-dialog modal-dialog-centered" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Delete product</h5>
                        <button type="button" class="btn-close" aria-label="Close" @onclick="CloseDeleteDialog" disabled="@isDeleting"></button>
                    </div>
                    <div class="modal-body">
                        <p class="mb-1">Are you sure you want to delete <strong>@productToDelete.Name</strong>?</p>
                        <p class="text-muted mb-0">This will also delete its variants, combinations, and stock records.</p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" @onclick="CloseDeleteDialog" disabled="@isDeleting">Cancel</button>
                        <button type="button" class="btn btn-danger" @onclick="ConfirmDeleteAsync" disabled="@isDeleting">
                            @if (isDeleting)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                            }
                            Confirm Delete
                        </button>
                    </div>
                </div>
            </div>
        </div>
        <div class="modal-backdrop fade show"></div>
    }
}

@code {
    private readonly int pageSize = 10;
    private PagedResult<ProductResponseDto> products = new();
    private int page = 1;
    private bool isLoading = true;
    private bool isDeleting;
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;
    private ProductResponseDto? productToDelete;

    protected override async Task OnInitializedAsync()
    {
        await LoadProductsAsync();
    }

    private async Task LoadProductsAsync(bool clearMessages = true)
    {
        isLoading = true;
        if (clearMessages)
        {
            errorMessage = string.Empty;
            successMessage = string.Empty;
        }

        try
        {
            products = await Api.GetProductsAsync(page, pageSize);
        }
        catch (Exception ex)
        {
            errorMessage = $"Unable to load products. {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task PreviousPage()
    {
        if (page <= 1)
        {
            return;
        }

        page--;
        await LoadProductsAsync();
    }

    private async Task NextPage()
    {
        if (page >= products.TotalPages)
        {
            return;
        }

        page++;
        await LoadProductsAsync();
    }

    private void GoToCreate()
    {
        Navigation.NavigateTo("/products/create");
    }

    private void GoToDetails(int id)
    {
        Navigation.NavigateTo($"/products/{id}");
    }

    private void OpenDeleteDialog(ProductResponseDto product)
    {
        errorMessage = string.Empty;
        successMessage = string.Empty;
        productToDelete = product;
    }

    private void CloseDeleteDialog()
    {
        if (isDeleting)
        {
            return;
        }

        productToDelete = null;
    }

    private async Task ConfirmDeleteAsync()
    {
        if (productToDelete is null)
        {
            return;
        }

        isDeleting = true;
        errorMessage = string.Empty;
        successMessage = string.Empty;

        try
        {
            var deletedProductName = productToDelete.Name;
            var success = await Api.DeleteProductAsync(productToDelete.Id);

            if (!success)
            {
                errorMessage = string.IsNullOrWhiteSpace(Api.LastErrorMessage)
                    ? "Unable to delete product."
                    : Api.LastErrorMessage;
                return;
            }

            productToDelete = null;
            successMessage = $"{deletedProductName} deleted successfully.";
            await LoadProductsAsync(clearMessages: false);
        }
        catch (Exception ex)
        {
            errorMessage = $"Unable to delete product. {ex.Message}";
        }
        finally
        {
            isDeleting = false;
        }
    }
}

@page "/products/{Id:int}"
@inject ApiService Api
@inject NavigationManager Navigation

<PageTitle>Product Details</PageTitle>

<div class="page-header">
    <div>
        <h4>@product?.Name</h4>
        <p>@(product?.Description ?? "No description")</p>
    </div>
    <a href="/products" class="btn-ghost">
        <i class="bi bi-arrow-left"></i> Back to Products
    </a>
</div>

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert-clean success">
        <i class="bi bi-check-circle"></i> @successMessage
    </div>
}
@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert-clean error">
        <i class="bi bi-exclamation-circle"></i> @errorMessage
    </div>
}

@if (isLoading)
{
    <div class="spinner-wrap"><div class="spinner"></div><span>Loading...</span></div>
}
else if (product != null)
{
    <div class="card mb-4">
        <div class="card-header-clean">
            <h6><i class="bi bi-pencil-square me-2"></i>Product Information</h6>
            @if (!isEditingProduct)
            {
                <button class="btn-ghost" @onclick="StartProductEdit" disabled="@isBusy">
                    <i class="bi bi-pencil"></i> Edit Product
                </button>
            }
        </div>
        <div class="p-4">
            @if (isEditingProduct)
            {
                <div class="row g-3 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label-clean">Product Name</label>
                        <input class="form-control-clean" @bind="productEditModel.Name" />
                    </div>
                    <div class="col-md-5">
                        <label class="form-label-clean">Description</label>
                        <input class="form-control-clean" @bind="productEditModel.Description" />
                    </div>
                    <div class="col-md-3">
                        <div class="d-flex gap-2">
                            <button class="btn-primary-custom" @onclick="SaveProductAsync" disabled="@isBusy">
                                <i class="bi bi-check-lg"></i> Save
                            </button>
                            <button class="btn-ghost" @onclick="CancelProductEdit" disabled="@isBusy">Cancel</button>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="row g-3">
                    <div class="col-md-4">
                        <span class="form-label-clean">Name</span>
                        <div style="font-weight:600;">@product.Name</div>
                    </div>
                    <div class="col-md-8">
                        <span class="form-label-clean">Description</span>
                        <div>@(product.Description ?? "No description")</div>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Variants section -->
    <div class="card mb-4">
        <div class="card-header-clean">
            <h6><i class="bi bi-tags me-2"></i>Variants</h6>
        </div>
        <div class="p-4">
            @if (!product.Variants.Any())
            {
                <div class="empty-state" style="padding:20px">
                    <i class="bi bi-tag" style="font-size:1.5rem"></i>
                    <p>No variants yet. Add one below.</p>
                </div>
            }
            else
            {
                <div class="d-flex flex-wrap gap-3 mb-4">
                    @foreach (var v in product.Variants)
                    {
                        <div class="card p-3 variant-card">
                            @if (editingVariantId == v.Id)
                            {
                                <div class="mb-2">
                                    <label class="form-label-clean">Variant Name</label>
                                    <input class="form-control-clean" @bind="editVariantName" />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label-clean">Values</label>
                                    <input class="form-control-clean" @bind="editVariantValuesText" placeholder="8GB, 16GB" />
                                </div>
                                <div class="d-flex gap-2">
                                    <button class="btn-primary-custom" @onclick="SaveVariantAsync" disabled="@isBusy">
                                        <i class="bi bi-check-lg"></i> Save
                                    </button>
                                    <button class="btn-ghost" @onclick="CancelVariantEdit" disabled="@isBusy">Cancel</button>
                                </div>
                            }
                            else
                            {
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div style="font-weight:600;font-size:0.85rem;color:var(--text-primary);">
                                        <i class="bi bi-tag-fill me-1" style="color:var(--primary);"></i>@v.Name
                                    </div>
                                    <div class="d-flex gap-1">
                                        <button class="btn-icon" style="width:24px;height:24px;font-size:0.75rem;" @onclick="() => StartVariantEdit(v)" disabled="@isBusy" title="Edit Variant">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn-icon danger" style="width:24px;height:24px;font-size:0.75rem;" @onclick="() => DeleteVariantAsync(v.Id)" disabled="@isBusy" title="Delete Variant">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </div>
                                <div class="d-flex flex-wrap gap-1">
                                    @foreach (var val in v.Values)
                                    {
                                        <span class="badge-pill badge-indigo">@val</span>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            }

            <!-- Add variant form -->
            <div style="border-top:1px solid var(--border);padding-top:20px;">
                <div style="font-weight:600;font-size:0.85rem;margin-bottom:12px;color:var(--text-secondary);">
                    <i class="bi bi-plus-circle me-1"></i> Add New Variant
                </div>
                <div class="row g-2 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label-clean">Variant Name</label>
                        <input class="form-control-clean"
                               list="variant-name-options"
                               @bind="newVariant.Name"
                               placeholder="Type or select variant" />
                        <datalist id="variant-name-options">
                            @foreach (var variant in product.Variants.OrderBy(v => v.Name))
                            {
                                <option value="@variant.Name"></option>
                            }
                        </datalist>
                        @if (IsExistingVariantName(newVariant.Name))
                        {
                            <div style="font-size:0.75rem;color:var(--text-muted);margin-top:4px;">
                                New values will be added to the existing variant.
                            </div>
                        }
                    </div>
                    <div class="col-md-5">
                        <label class="form-label-clean">Values (comma separated)</label>
                        <input class="form-control-clean" @bind="variantValuesText" placeholder="e.g. S, M, L, XL" />
                    </div>
                    <div class="col-md-2">
                        <button class="btn-primary-custom w-100" @onclick="AddVariantAsync" disabled="@isBusy">
                            @if (isBusy)
                            {
                                <div class="spinner" style="width:14px;height:14px;border-width:2px;"></div>
                            }
                            else
                            {
                                <i class="bi bi-plus-lg"></i>
                            }
                            Add
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Stock section -->
    <div class="card">
        <div class="card-header-clean">
            <h6><i class="bi bi-archive me-2"></i>Stock by Combination</h6>
            <span style="font-size:0.78rem;color:var(--text-muted);">
                @product.Combinations.Count combinations
            </span>
        </div>

        @if (!product.Combinations.Any())
        {
            <div class="empty-state">
                <i class="bi bi-inbox"></i>
                <p>No combinations yet. Add variants first.</p>
            </div>
        }
        else
        {
            <table class="table-clean">
                <thead>
                    <tr>
                        <th>Combination</th>
                        <th>Key</th>
                        <th>Stock</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var combo in product.Combinations)
                    {
                        <tr>
                            <td data-label="Combination"><span style="font-weight:500;">@combo.DisplayLabel</span></td>
                            <td data-label="Key">
                                <code style="font-size:0.75rem;background:var(--surface);padding:2px 8px;border-radius:5px;color:var(--primary);">
                                    @combo.CombinationKey
                                </code>
                            </td>
                            <td data-label="Stock">
                                @{
                                    var qty = combo.CurrentStock;
                                    var qtyClass = qty > 20 ? "qty-high" : qty > 5 ? "qty-medium" : "qty-low";
                                }
                                <span class="qty-display @qtyClass">@qty</span>
                                <span style="font-size:0.75rem;color:var(--text-muted);margin-left:4px;">units</span>
                            </td>
                            <td data-label="Actions">
                                <div class="d-flex align-items-center gap-2">
                                    <input type="number" class="form-control-clean stock-qty-input"
                                        @bind="stockQuantities[combo.Id]" min="1" placeholder="Qty" />
                                    <button class="btn-icon success" @onclick="() => AddStockAsync(combo.Id)" disabled="@isBusy" title="Add">
                                        <i class="bi bi-plus-lg"></i>
                                    </button>
                                    <button class="btn-icon danger" @onclick="() => RemoveStockAsync(combo.Id)" disabled="@isBusy" title="Remove">
                                        <i class="bi bi-dash-lg"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private ProductResponseDto? product;
    private List<StockResponseDto> stockRows = [];
    private readonly AddVariantDto newVariant = new();
    private readonly UpdateProductDto productEditModel = new();
    private readonly Dictionary<int, int> stockQuantities = [];
    private string variantValuesText = string.Empty;
    private int? editingVariantId;
    private string editVariantName = string.Empty;
    private string editVariantValuesText = string.Empty;
    private string successMessage = string.Empty;
    private string errorMessage = string.Empty;
    private bool isLoading = true;
    private bool isBusy;
    private bool isEditingProduct;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        errorMessage = string.Empty;

        try
        {
            product = await Api.GetProductAsync(Id);
            stockRows = await Api.GetProductStockAsync(Id);
            productEditModel.Name = product.Name;
            productEditModel.Description = product.Description;

            foreach (var stock in stockRows)
            {
                stockQuantities.TryAdd(stock.CombinationId, 1);
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Unable to load product details. {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task AddVariantAsync()
    {
        isBusy = true;
        ClearMessages();

        try
        {
            var normalizedName = newVariant.Name.Trim();

            if (string.IsNullOrWhiteSpace(normalizedName))
            {
                ShowError("Variant name is required.");
                return;
            }

            newVariant.Values = variantValuesText
                .Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToList();

            if (newVariant.Values.Count == 0)
            {
                ShowError("Enter at least one variant value.");
                return;
            }

            newVariant.Name = normalizedName;

            var success = await Api.AddVariantAsync(Id, newVariant);

            if (!success)
            {
                ShowError(string.IsNullOrWhiteSpace(Api.LastErrorMessage) ? "Unable to add variant." : Api.LastErrorMessage);
                return;
            }

            ShowSuccess(IsExistingVariantName(normalizedName)
                ? "Variant values added successfully."
                : "Variant added successfully.");
            newVariant.Name = string.Empty;
            newVariant.Values = [];
            variantValuesText = string.Empty;
            await LoadAsync();
        }
        catch (Exception ex)
        {
            ShowError($"Unable to add variant. {ex.Message}");
        }
        finally
        {
            isBusy = false;
        }
    }

    private void StartProductEdit()
    {
        if (product is null)
        {
            return;
        }

        ClearMessages();
        productEditModel.Name = product.Name;
        productEditModel.Description = product.Description;
        isEditingProduct = true;
    }

    private void CancelProductEdit()
    {
        isEditingProduct = false;
    }

    private async Task SaveProductAsync()
    {
        isBusy = true;
        ClearMessages();

        try
        {
            productEditModel.Name = productEditModel.Name.Trim();

            if (string.IsNullOrWhiteSpace(productEditModel.Name))
            {
                ShowError("Product name is required.");
                return;
            }

            var success = await Api.UpdateProductAsync(Id, productEditModel);

            if (!success)
            {
                ShowError(string.IsNullOrWhiteSpace(Api.LastErrorMessage) ? "Unable to update product." : Api.LastErrorMessage);
                return;
            }

            ShowSuccess("Product updated successfully.");
            isEditingProduct = false;
            await LoadAsync();
        }
        catch (Exception ex)
        {
            ShowError($"Unable to update product. {ex.Message}");
        }
        finally
        {
            isBusy = false;
        }
    }

    private void StartVariantEdit(VariantResponseDto variant)
    {
        ClearMessages();
        editingVariantId = variant.Id;
        editVariantName = variant.Name;
        editVariantValuesText = string.Join(", ", variant.Values);
    }

    private void CancelVariantEdit()
    {
        editingVariantId = null;
        editVariantName = string.Empty;
        editVariantValuesText = string.Empty;
    }

    private async Task SaveVariantAsync()
    {
        if (!editingVariantId.HasValue)
        {
            return;
        }

        isBusy = true;
        ClearMessages();

        try
        {
            var normalizedName = editVariantName.Trim();

            if (string.IsNullOrWhiteSpace(normalizedName))
            {
                ShowError("Variant name is required.");
                return;
            }

            var values = editVariantValuesText
                .Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToList();

            if (values.Count == 0)
            {
                ShowError("Enter at least one variant value.");
                return;
            }

            var success = await Api.UpdateVariantAsync(editingVariantId.Value, new UpdateVariantDto
            {
                Name = normalizedName,
                Values = values
            });

            if (!success)
            {
                ShowError(string.IsNullOrWhiteSpace(Api.LastErrorMessage) ? "Unable to update variant." : Api.LastErrorMessage);
                return;
            }

            ShowSuccess("Variant updated successfully.");
            CancelVariantEdit();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            ShowError($"Unable to update variant. {ex.Message}");
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task DeleteVariantAsync(int variantId)
    {
        isBusy = true;
        ClearMessages();

        try
        {
            var success = await Api.DeleteVariantAsync(variantId);

            if (!success)
            {
                ShowError(string.IsNullOrWhiteSpace(Api.LastErrorMessage) ? "Unable to delete variant." : Api.LastErrorMessage);
                return;
            }

            ShowSuccess("Variant deleted successfully.");
            await LoadAsync();
        }
        catch (Exception ex)
        {
            ShowError($"Unable to delete variant. {ex.Message}");
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task AddStockAsync(int combinationId)
    {
        isBusy = true;
        ClearMessages();

        try
        {
            var quantity = Math.Max(stockQuantities[combinationId], 1);
            var success = await Api.AddStockAsync(new AddStockDto { CombinationId = combinationId, Quantity = quantity });

            if (!success)
            {
                ShowError(string.IsNullOrWhiteSpace(Api.LastErrorMessage) ? "Unable to add stock." : Api.LastErrorMessage);
                return;
            }

            ShowSuccess("Stock added successfully.");
            await LoadAsync();
        }
        catch (Exception ex)
        {
            ShowError($"Unable to add stock. {ex.Message}");
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task RemoveStockAsync(int combinationId)
    {
        isBusy = true;
        ClearMessages();

        try
        {
            var quantity = Math.Max(stockQuantities[combinationId], 1);
            var result = await Api.RemoveStockAsync(new RemoveStockDto { CombinationId = combinationId, Quantity = quantity });

            if (!result.success)
            {
                ShowError(result.errorMessage);
                return;
            }

            ShowSuccess("Stock removed successfully.");
            await LoadAsync();
        }
        catch (Exception ex)
        {
            ShowError($"Unable to remove stock. {ex.Message}");
        }
        finally
        {
            isBusy = false;
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/products");
    }

    private bool IsExistingVariantName(string? variantName)
    {
        if (product is null || string.IsNullOrWhiteSpace(variantName))
        {
            return false;
        }

        return product.Variants.Any(variant =>
            string.Equals(variant.Name, variantName.Trim(), StringComparison.OrdinalIgnoreCase));
    }

    private CancellationTokenSource? toastCancellationTokenSource;

    private void ShowSuccess(string message)
    {
        successMessage = message;
        errorMessage = string.Empty;
        ScheduleToastClear();
    }

    private void ShowError(string message)
    {
        errorMessage = message;
        successMessage = string.Empty;
        ScheduleToastClear();
    }

    private void ClearMessages()
    {
        toastCancellationTokenSource?.Cancel();
        successMessage = string.Empty;
        errorMessage = string.Empty;
    }

    private void ScheduleToastClear()
    {
        toastCancellationTokenSource?.Cancel();
        toastCancellationTokenSource = new CancellationTokenSource();
        var token = toastCancellationTokenSource.Token;

        _ = ClearToastAfterDelayAsync(token);
    }

    private async Task ClearToastAfterDelayAsync(CancellationToken cancellationToken)
    {
        try
        {
            await Task.Delay(TimeSpan.FromSeconds(5), cancellationToken);
            successMessage = string.Empty;
            errorMessage = string.Empty;
            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException)
        {
        }
    }
}

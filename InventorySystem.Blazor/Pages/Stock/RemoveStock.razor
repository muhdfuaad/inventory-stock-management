@page "/stock/remove"
@inject ApiService Api

<PageTitle>Remove Stock</PageTitle>

<div class="page-header">
    <div>
        <h4>Remove Stock</h4>
        <p>Decrease inventory for a product combination</p>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert-clean success"><i class="bi bi-check-circle"></i> @successMessage</div>
}

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert-clean error"><i class="bi bi-exclamation-circle"></i> @errorMessage</div>
}

@if (isLoading)
{
    <div class="spinner-wrap">
        <div class="spinner"></div>
        <span>Loading products...</span>
    </div>
}
else if (products.Count == 0)
{
    <div class="alert-clean info"><i class="bi bi-info-circle"></i> No products available.</div>
}
else
{
    <div class="row">
        <div class="col-md-5">
            <div class="card p-4">
                <div class="mb-3">
                    <label class="form-label-clean">Select Product</label>
                    <select class="form-control-clean" value="@selectedProductId" @onchange="OnProductChangedAsync">
                        <option value="0">— Choose product —</option>
                        @foreach (var product in products)
                        {
                            <option value="@product.Id">@product.Name</option>
                        }
                    </select>
                </div>

                @if (isStockLoading)
                {
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <div class="spinner" style="width:14px;height:14px;border-width:2px;"></div>
                        <span class="text-muted">Loading combinations...</span>
                    </div>
                }
                else if (selectedProductId > 0 && stockRows.Count == 0)
                {
                    <div class="alert-clean error"><i class="bi bi-info-circle"></i> No combinations available for this product.</div>
                }

                @if (stockRows.Any())
                {
                    <div class="mb-3">
                        <label class="form-label-clean">Select Combination</label>
                        <select class="form-control-clean" @bind="model.CombinationId">
                            <option value="0">— Choose combination —</option>
                            @foreach (var stock in stockRows)
                            {
                                <option value="@stock.CombinationId">@stock.DisplayLabel (Stock: @stock.Quantity)</option>
                            }
                        </select>
                    </div>

                    <div class="mb-4">
                        <label class="form-label-clean">Quantity to Remove</label>
                        <input type="number" class="form-control-clean" @bind="model.Quantity" min="1" placeholder="Enter quantity" />
                    </div>

                    <button class="btn-danger-custom" @onclick="SubmitAsync" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <div class="spinner" style="width:14px;height:14px;border-width:2px;"></div>
                            <span>Removing...</span>
                        }
                        else
                        {
                            <i class="bi bi-dash-circle"></i>
                            <span>Remove Stock</span>
                        }
                    </button>
                }
            </div>
        </div>
    </div>
}

@code {
    private readonly RemoveStockDto model = new();
    private List<ProductResponseDto> products = [];
    private List<StockResponseDto> stockRows = [];
    private int selectedProductId;
    private bool isLoading = true;
    private bool isStockLoading;
    private bool isSaving;
    private string successMessage = string.Empty;
    private string errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadProductsAsync();
    }

    private async Task LoadProductsAsync()
    {
        isLoading = true;
        errorMessage = string.Empty;

        try
        {
            var result = await Api.GetProductsAsync(1, 100);
            products = result.Items;
        }
        catch (Exception ex)
        {
            errorMessage = $"Unable to load products. {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task OnProductChangedAsync(ChangeEventArgs args)
    {
        selectedProductId = int.TryParse(args.Value?.ToString(), out var value) ? value : 0;
        model.CombinationId = 0;
        stockRows = [];

        if (selectedProductId > 0)
        {
            await LoadStockAsync();
        }
    }

    private async Task LoadStockAsync()
    {
        isStockLoading = true;
        errorMessage = string.Empty;

        try
        {
            stockRows = await Api.GetProductStockAsync(selectedProductId);
        }
        catch (Exception ex)
        {
            errorMessage = $"Unable to load combinations. {ex.Message}";
        }
        finally
        {
            isStockLoading = false;
        }
    }

    private async Task SubmitAsync()
    {
        isSaving = true;
        successMessage = string.Empty;
        errorMessage = string.Empty;

        try
        {
            if (model.CombinationId <= 0)
            {
                errorMessage = "Select a combination.";
                return;
            }

            var result = await Api.RemoveStockAsync(model);

            if (!result.success)
            {
                errorMessage = result.errorMessage;
                return;
            }

            successMessage = "Stock removed successfully.";
            await LoadStockAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Unable to remove stock. {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }
}

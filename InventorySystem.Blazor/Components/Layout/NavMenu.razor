<div class="sidebar">
    <div class="sidebar-brand-row">
        <div class="sidebar-brand">
            <h5><i class="bi bi-box-seam me-2"></i>InventoryOS</h5>
            <span>Stock Management</span>
        </div>
        <button class="mobile-menu-toggle" type="button" @onclick="ToggleMenu" aria-label="Toggle navigation menu" aria-expanded="@IsMenuExpanded">
            <i class="bi @(isMenuOpen ? "bi-x-lg" : "bi-list")"></i>
        </button>
    </div>

    <nav class="sidebar-nav @(isMenuOpen ? "open" : "")">
        <ul class="nav flex-column gap-1 mt-2">
            <li class="nav-item">
                <NavLink class="nav-link" href="products" Match="NavLinkMatch.Prefix" @onclick="CloseMenu">
                    <i class="bi bi-grid-1x2"></i> Products
                </NavLink>
            </li>
            <li class="nav-item">
                <NavLink class="nav-link" href="stock/add" Match="NavLinkMatch.Prefix" @onclick="CloseMenu">
                    <i class="bi bi-plus-circle"></i> Add Stock
                </NavLink>
            </li>
            <li class="nav-item">
                <NavLink class="nav-link" href="stock/remove" Match="NavLinkMatch.Prefix" @onclick="CloseMenu">
                    <i class="bi bi-dash-circle"></i> Remove Stock
                </NavLink>
            </li>
        </ul>
    </nav>

    <div style="padding: 16px 20px; border-top: 1px solid rgba(255,255,255,0.08);">
        <span style="font-size:0.72rem; color: var(--sidebar-text); opacity:0.5;">
            Vikncodes Machine Test
        </span>
    </div>
</div>

@code {
    private bool isMenuOpen;

    private string IsMenuExpanded => isMenuOpen ? "true" : "false";

    private void ToggleMenu()
    {
        isMenuOpen = !isMenuOpen;
    }

    private void CloseMenu()
    {
        isMenuOpen = false;
    }
}
